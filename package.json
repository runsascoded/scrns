{
  "name": "scrns",
  "version": "0.3.0-dist.ed7262f",
  "description": "Automated screenshots with Playwright/Puppeteer - wait for selectors, configurable viewports, CLI",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "bin": {
    "scrns": "./cli.js"
  },
  "keywords": [
    "playwright",
    "puppeteer",
    "screenshots",
    "automation",
    "cli",
    "testing"
  ],
  "author": "Ryan Williams",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/runsascoded/js/scrns"
  },
  "peerDependencies": {
    "puppeteer": ">=20"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^12.1.0",
    "gifenc": "^1.0.3",
    "playwright": "^1.50.0",
    "pngjs": "^7.0.0"
  }
}
